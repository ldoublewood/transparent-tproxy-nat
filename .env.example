# =============================================================================
# Transparent TPROXY NAT Gateway — Configuration
# =============================================================================
# Copy this file to .env and edit the values to match your environment:
#   cp .env.example .env
#
# Then deploy with a single command:
#   sudo bash deploy.sh
# =============================================================================

# LAN interface — the network interface facing your local clients (WiFi AP side)
LAN_IFACE=wlo1

# WAN interface — the network interface with internet access
# For single-interface (hairpin) NAT, set this to the same value as LAN_IFACE
WAN_IFACE=wlo1

# LAN subnet in CIDR notation (must include the gateway host itself)
LAN_SUBNET=192.168.0.0/24

# TPROXY listening port — must match the port your proxy listens on
TPROXY_PORT=17893

# Firewall mark used to tag TPROXY-intercepted packets for policy routing
# Must match between nftables rules and the policy routing table
TPROXY_MARK=1

# Policy routing table ID — an arbitrary number that doesn't conflict with system tables
RT_TABLE=100

# Set to "yes" to automatically install systemd services for persistence across reboots
INSTALL_SERVICES=no

# Multi-TPROXY mode — enable if you have multiple LAN subnets each with its own proxy port
# When enabled, lan_tproxy_pair.json defines the subnet→port mappings
# (LAN_SUBNET and TPROXY_PORT above are ignored in multi mode)
ENABLED_MULTI_TPROXY=no
